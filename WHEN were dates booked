    }
  });
  if (year === "all") document.querySelector(".legend-item[data-year='all']").classList.add("active");

  // Apply to all wedding cells
  document.querySelectorAll(".day-cell.wedding").forEach(cell => {
    const sy = cell.dataset.saleyear;
    if (year === "all" || String(sy) === String(year)) {
      cell.classList.remove("dimmed-cell");
    } else {
      cell.classList.add("dimmed-cell");
    }
  });

  updateStats();
}

function updateStats() {
  const activeTab = document.querySelector(".tab.active");
  const yearStr = activeTab ? activeTab.id.replace("tab-", "") : "";
  const vmap = ALL_DATA[activeVenue] || {};

  let count = 0;
  for (const [key, sy] of Object.entries(vmap)) {
    if (!key.startsWith(yearStr)) continue;
    if (activeFilter === "all") { count++; continue; }
    const syKey = sy === "Unknown" ? "Unknown" : parseInt(sy);
    if (String(syKey) === String(activeFilter)) count++;
  }

  document.getElementById("stat-total").textContent = count;
  document.getElementById("stat-venue").textContent = activeVenue;
  document.getElementById("stat-filter").textContent = activeFilter === "all" ? "All sale years" : (activeFilter === "Unknown" ? "Unknown sale date" : "Sold in " + activeFilter);

  // Update tab badges
  WEDDING_YEARS.forEach(y => {
    let c = 0;
    for (const [key, sy] of Object.entries(vmap)) {
      if (!key.startsWith(String(y))) continue;
      if (activeFilter === "all") { c++; continue; }
      const syKey = sy === "Unknown" ? "Unknown" : parseInt(sy);
      if (String(syKey) === String(activeFilter)) c++;
    }
    const badge = document.getElementById("tbadge-" + y);
    if (badge) badge.textContent = c;
  });

  // Update active tab badge colour
  const activeTabEl = document.querySelector(".tab.active");
  if (activeTabEl) {
    const badge = activeTabEl.querySelector(".tab-badge");
    if (badge) { badge.style.background = VENUE_COLOURS[activeVenue] || "#333"; badge.style.color = "#fff"; }
  }
}

// ── Init ──
buildAllPanels();
updateLegendCounts();
updateStats();
</script>
</body>
</html>
