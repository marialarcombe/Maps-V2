function getDaysInMonth(y, m) { return new Date(y, m + 1, 0).getDate(); }
function getFirstDOW(y, m) { let d = new Date(y, m, 1).getDay(); return d === 0 ? 6 : d - 1; }

function formatDate(key) {
  const [y, m, d] = key.split("-");
  return `${parseInt(d)} ${MONTHS[parseInt(m)-1]} ${y}`;
}

// Compute sale year counts for current venue
function venueYearCounts(venue) {
  const vmap = ALL_DATA[venue] || {};
  const counts = {};
  for (const sy of Object.values(vmap)) {
    const k = sy === "Unknown" ? "Unknown" : parseInt(sy);
    counts[k] = (counts[k] || 0) + 1;
  }
  return counts;
}

function updateLegendCounts() {
  const counts = venueYearCounts(activeVenue);
  ["2021","2022","2023","2024","2025","2026","Unknown"].forEach(y => {
    const el = document.getElementById("lc-" + y);
    const key = y === "Unknown" ? "Unknown" : parseInt(y);
    const n = counts[key] || 0;
    if (el) el.textContent = n > 0 ? "(" + n + ")" : "";
  });
}

function buildAllPanels() {
  const tabsEl = document.getElementById("year-tabs");
  const panelsEl = document.getElementById("calendar-panels");
  tabsEl.innerHTML = "";
  panelsEl.innerHTML = "";

  WEDDING_YEARS.forEach((year, idx) => {
    const tab = document.createElement("div");
    tab.className = "tab" + (idx === 0 ? " active" : "");
    tab.id = "tab-" + year;
    tab.onclick = () => switchYear(year);
    const cnt = (ALL_COUNTS[activeVenue] || {})[year] || 0;
    tab.innerHTML = year + `<span class="tab-badge" id="tbadge-${year}">${cnt}</span>`;
    tabsEl.appendChild(tab);

    const panel = document.createElement("div");
    panel.className = "calendar-panel" + (idx === 0 ? " active" : "");
    panel.id = "panel-" + year;

    const grid = document.createElement("div");
    grid.className = "months-grid";
    for (let m = 0; m < 12; m++) grid.appendChild(buildMonth(year, m));
    panel.appendChild(grid);
    panelsEl.appendChild(panel);
  });
}

function buildMonth(year, month) {
  const vmap = ALL_DATA[activeVenue] || {};
  const daysInMonth = getDaysInMonth(year, month);
  const firstDay = getFirstDOW(year, month);
  const vcol = VENUE_COLOURS[activeVenue] || "#333";

  let monthWeddings = 0;
  for (let d = 1; d <= daysInMonth; d++) {
    const k = `${year}-${String(month+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
    if (vmap[k] !== undefined) monthWeddings++;
  }

  const block = document.createElement("div");
  block.className = "month-block";

  const header = document.createElement("div");
  header.className = "month-name";
  header.style.background = vcol;
  header.innerHTML = `${MONTHS[month]} <span class="month-count">${monthWeddings > 0 ? monthWeddings + (monthWeddings === 1 ? " wedding" : " weddings") : ""}</span>`;
  block.appendChild(header);

  const dayHeaders = document.createElement("div");
  dayHeaders.className = "day-headers";
  DAY_ABBR.forEach(d => {
    const h = document.createElement("div");
    h.className = "day-header";
    h.textContent = d;
    dayHeaders.appendChild(h);
  });
  block.appendChild(dayHeaders);

  const daysGrid = document.createElement("div");
  daysGrid.className = "days-grid";

  for (let i = 0; i < firstDay; i++) {
    const e = document.createElement("div");
    e.className = "day-cell empty";
    daysGrid.appendChild(e);
  }

  for (let d = 1; d <= daysInMonth; d++) {
    const key = `${year}-${String(month+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
    const sy = vmap[key];
    const cell = document.createElement("div");
    cell.className = "day-cell";
    cell.textContent = d;
    cell.dataset.datekey = key;

    if (sy !== undefined) {
      const syKey = sy === "Unknown" ? "Unknown" : parseInt(sy);
      cell.classList.add("wedding");
      cell.dataset.saleyear = String(syKey);
      cell.style.background = SALE_COLOURS[syKey] || "#ddd";
      cell.addEventListener("mouseenter", showTooltip);
      cell.addEventListener("mouseleave", hideTooltip);
      cell.addEventListener("mousemove", moveTooltip);

      // Apply filter dimming
      if (activeFilter !== "all") {
        const filterKey = activeFilter === "Unknown" ? "Unknown" : parseInt(activeFilter);
        if (String(syKey) !== String(filterKey)) cell.classList.add("dimmed-cell");
      }
    }
    daysGrid.appendChild(cell);
  }

  const total = firstDay + daysInMonth;
  const rem = total % 7;
  if (rem !== 0) {
    for (let i = 0; i < 7 - rem; i++) {
      const e = document.createElement("div");
      e.className = "day-cell empty";
      daysGrid.appendChild(e);
    }
  }

  block.appendChild(daysGrid);
  return block;
}

function showTooltip(e) {
  const cell = e.currentTarget;
  const key = cell.dataset.datekey;
  const sy = cell.dataset.saleyear;
  const colour = SALE_COLOURS[sy === "Unknown" ? "Unknown" : parseInt(sy)] || "#ddd";
  const label = sy === "Unknown" ? "Unknown sale date" : "Sold in " + sy;
  const tt = document.getElementById("tooltip");
  tt.innerHTML = `<strong>${formatDate(key)}</strong><span class="tt-swatch" style="background:${colour};"></span>${label}`;
  tt.style.display = "block";
  moveTooltip(e);
}
function hideTooltip() { document.getElementById("tooltip").style.display = "none"; }
function moveTooltip(e) {
  const tt = document.getElementById("tooltip");
  const x = e.clientX + 14;
  const y = e.clientY - 10;
  tt.style.left = Math.min(x, window.innerWidth - 220) + "px";
  tt.style.top = (y < 10 ? 10 : y) + "px";
}

function switchYear(year) {
  document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
  document.querySelectorAll(".calendar-panel").forEach(p => p.classList.remove("active"));
  const tab = document.getElementById("tab-" + year);
  const panel = document.getElementById("panel-" + year);
  if (tab) { tab.classList.add("active"); tab.querySelector(".tab-badge").style.background = VENUE_COLOURS[activeVenue] || "#333"; }
  if (panel) panel.classList.add("active");
  updateStats();
}

function switchVenue(venue) {
  activeVenue = venue;
  activeFilter = "all";

  // Update stripe
  document.getElementById("venue-stripe").style.background = VENUE_COLOURS[venue] || "#333";

  // Reset legend
  document.querySelectorAll(".legend-item").forEach(el => {
    el.classList.remove("active", "dimmed");
  });
  document.querySelector(".legend-item[data-year='all']").classList.add("active");

  // Update tab badge colours
  WEDDING_YEARS.forEach(y => {
    const badge = document.getElementById("tbadge-" + y);
    if (badge) badge.style.background = "#eee", badge.style.color = "#777";
  });

  // Rebuild all panels
  buildAllPanels();
  updateLegendCounts();
  updateStats();
}

function filterYear(year) {
  activeFilter = year;

  document.querySelectorAll(".legend-item").forEach(el => {
    el.classList.remove("active", "dimmed");
    const ey = el.dataset.year;
    if (year === "all") {
      // no dimming
    } else {
      if (String(ey) === String(year) || ey === "all") el.classList.add("active");
